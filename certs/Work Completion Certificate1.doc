    </tr>
    <!-- Empty rows to match height if needed -->
    <tr><td colspan="6" style="height: 50px;"></td></tr>
</table>

<!-- Remarks Section -->
<div style="border: 1px solid black; padding: 5px; margin-bottom: 10px; background-color: #f2f2f2;">
    <b>Remarks</b><br>
    <b>CEA APPROVALS</b> – 2nd & 3rd Milestone 60 % Payment shall be released upon receipt of Work Completion for CEA Approval RTC1 W2, Kurudhagi ,Karnataka
</div>

<!-- Footer / Signatures -->
