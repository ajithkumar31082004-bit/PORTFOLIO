            RTC1 W2, Kurudhagi ,Karnataka<br>
            <b>PAN NO AAGCR3403F</b><br>
            <b>GST NO 29AAGCR3403F1ZK</b>
        </td>
        <td width="50%" style="padding: 0;">
            <table style="width: 100%; border: none; margin: 0;">
                <tr>
                    <td style="border-bottom: 1px solid black; border-right: 1px solid black; width: 40%; background-color: #f2f2f2;">WCC NO</td>
                    <td style="border-bottom: 1px solid black;">SRS/RENEW/K/31</td>
                </tr>
                <tr>
                    <td style="border-bottom: 1px solid black; border-right: 1px solid black; background-color: #f2f2f2;">WCC DATE</td>
                    <td style="border-bottom: 1px solid black;">13.03.2025</td>
                </tr>
                <tr>
                    <td style="border-bottom: 1px solid black; border-right: 1px solid black; background-color: #f2f2f2;">PO NO</td>
                    <td style="border-bottom: 1px solid black;">4300058675</td>
                </tr>
                <tr>
                    <td style="border-bottom: 1px solid black; border-right: 1px solid black; background-color: #f2f2f2;">PO DATE</td>
                    <td style="border-bottom: 1px solid black;">02.07.2024</td>
                </tr>
                <tr>
                    <td style="border-bottom: 1px solid black; border-right: 1px solid black; background-color: #f2f2f2;">Work start date</td>
                    <td style="border-bottom: 1px solid black;">05.07.2024</td>
                </tr>
                <tr>
                    <td style="border-bottom: 1px solid black; border-right: 1px solid black; background-color: #f2f2f2;">Work completion date</td>
                    <td style="border-bottom: 1px solid black;">06.02.2025</td>
                </tr>
                <tr>
                    <td style="border-right: 1px solid black; background-color: #f2f2f2;">Project Name</td>
                    <td>RTC1 W2, Kurudhagi ,Karnataka</td>
                </tr>
            </table>
        </td>
    </tr>
</table>

<!-- Main Content Table -->
<table>
    <tr class="bg-gray">
        <th width="10%">PO's No</th>
        <th width="40%">Description of work</th>
        <th width="8%">UOM</th>
        <th width="10%">Quantity completed</th>
        <th width="15%">Service code/SAC code</th>
        <th width="17%">Status of work completed</th>
    </tr>
    <tr>
        <td></td>
        <td><b>2nd & 3rd Milestone RTC1 W2, Kurudhagi ,KA</b></td>
        <td></td>
        <td></td>
        <td></td>
        <td></td>
    </tr>
