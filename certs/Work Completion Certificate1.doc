<html>
<head>
<style>
    body { font-family: Arial, sans-serif; font-size: 10pt; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 10px; }
    td, th { border: 1px solid black; padding: 5px; vertical-align: top; }
    .header-title { font-size: 14pt; font-weight: bold; text-align: center; background-color: #e6e6e6; border: 1px solid black; padding: 5px; }
    .company-name { font-size: 12pt; font-weight: bold; text-align: center; }
    .address { text-align: center; font-size: 10pt; }
    .bold { font-weight: bold; }
    .bg-gray { background-color: #e6e6e6; }
    .no-border { border: none; }
    .signature-area { height: 60px; }
</style>
</head>
<body>

<!-- Title Section -->
<div class="header-title">WORK COMPLETION CERTIFICATE</div>
<div style="border: 1px solid black; border-top: none; padding: 5px;">
    <div class="company-name">SUMUKH RENEWABLE SOLUTIONS</div>
    <div class="address">No 29, 2nd main road, R R Residency, Ullala, Bengaluru.</div>
    <br>
    <table style="width: 100%; border: none; margin: 0;">
        <tr>
            <td style="border: none;"><b>GST NO :</b> 29ADTFS8806N1ZW</td>
            <td style="border: none; text-align: right;"><b>PAN NO:</b> ADTFS8806N</td>
        </tr>
        <tr>
            <td style="border: none;"><b>Vendor Code:</b> 108751</td>
            <td style="border: none;"></td>
        </tr>
    </table>
</div>

<!-- Header Details Table -->
